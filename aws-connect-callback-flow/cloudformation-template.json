{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "AWS Connect Callback IVR System - Infrastructure Setup",
  "Parameters": {
    "ConnectInstanceId": {
      "Type": "String",
      "Description": "AWS Connect Instance ID"
    },
    "ConnectInstanceArn": {
      "Type": "String",
      "Description": "AWS Connect Instance ARN"
    }
  },
  "Resources": {
    "CallbackRequestsTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": "callback-requests",
        "AttributeDefinitions": [
          {
            "AttributeName": "CallbackId",
            "AttributeType": "S"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "CallbackId",
            "KeyType": "HASH"
          }
        ],
        "BillingMode": "PAY_PER_REQUEST",
        "PointInTimeRecoverySpecification": {
          "PointInTimeRecoveryEnabled": true
        },
        "Tags": [
          {
            "Key": "Application",
            "Value": "AWS-Connect-Callback"
          }
        ]
      }
    },
    "LambdaExecutionRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "ConnectCallbackLambdaRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ],
        "Policies": [
          {
            "PolicyName": "ConnectCallbackPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "dynamodb:GetItem",
                    "dynamodb:PutItem",
                    "dynamodb:UpdateItem",
                    "dynamodb:Query",
                    "dynamodb:Scan"
                  ],
                  "Resource": {
                    "Fn::GetAtt": [
                      "CallbackRequestsTable",
                      "Arn"
                    ]
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "connect:StartOutboundVoiceContact",
                    "connect:DescribeContactFlow",
                    "connect:ListContactFlows"
                  ],
                  "Resource": [
                    {
                      "Ref": "ConnectInstanceArn"
                    },
                    {
                      "Fn::Sub": "${ConnectInstanceArn}/*"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "CallbackSchedulerFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "FunctionName": "CallbackScheduler",
        "Runtime": "python3.9",
        "Handler": "callback-scheduler.lambda_handler",
        "Role": {
          "Fn::GetAtt": [
            "LambdaExecutionRole",
            "Arn"
          ]
        },
        "Code": {
          "ZipFile": "# Placeholder - replace with actual function code"
        },
        "Environment": {
          "Variables": {
            "CALLBACK_TABLE": {
              "Ref": "CallbackRequestsTable"
            },
            "CONNECT_INSTANCE_ID": {
              "Ref": "ConnectInstanceId"
            }
          }
        },
        "Timeout": 60,
        "Tags": [
          {
            "Key": "Application",
            "Value": "AWS-Connect-Callback"
          }
        ]
      }
    },
    "RetrieveCallbackInfoFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "FunctionName": "RetrieveCallbackInfo",
        "Runtime": "python3.9",
        "Handler": "retrieve-callback-info.lambda_handler",
        "Role": {
          "Fn::GetAtt": [
            "LambdaExecutionRole",
            "Arn"
          ]
        },
        "Code": {
          "ZipFile": "# Placeholder - replace with actual function code"
        },
        "Environment": {
          "Variables": {
            "CALLBACK_TABLE": {
              "Ref": "CallbackRequestsTable"
            }
          }
        },
        "Timeout": 60
      }
    },
    "UpdateCallbackStatusFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "FunctionName": "UpdateCallbackStatus",
        "Runtime": "python3.9",
        "Handler": "update-callback-status.lambda_handler",
        "Role": {
          "Fn::GetAtt": [
            "LambdaExecutionRole",
            "Arn"
          ]
        },
        "Code": {
          "ZipFile": "# Placeholder - replace with actual function code"
        },
        "Environment": {
          "Variables": {
            "CALLBACK_TABLE": {
              "Ref": "CallbackRequestsTable"
            }
          }
        },
        "Timeout": 60
      }
    },
    "InitiateOutboundCallFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "FunctionName": "InitiateOutboundCall",
        "Runtime": "python3.9",
        "Handler": "initiate-outbound-call.lambda_handler",
        "Role": {
          "Fn::GetAtt": [
            "LambdaExecutionRole",
            "Arn"
          ]
        },
        "Code": {
          "ZipFile": "# Placeholder - replace with actual function code"
        },
        "Environment": {
          "Variables": {
            "CALLBACK_TABLE": {
              "Ref": "CallbackRequestsTable"
            },
            "CONNECT_INSTANCE_ID": {
              "Ref": "ConnectInstanceId"
            }
          }
        },
        "Timeout": 60
      }
    },
    "ConnectLambdaInvokePermission1": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "FunctionName": {
          "Ref": "CallbackSchedulerFunction"
        },
        "Action": "lambda:InvokeFunction",
        "Principal": "connect.amazonaws.com",
        "SourceAccount": {
          "Ref": "AWS::AccountId"
        }
      }
    },
    "ConnectLambdaInvokePermission2": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "FunctionName": {
          "Ref": "RetrieveCallbackInfoFunction"
        },
        "Action": "lambda:InvokeFunction",
        "Principal": "connect.amazonaws.com",
        "SourceAccount": {
          "Ref": "AWS::AccountId"
        }
      }
    },
    "ConnectLambdaInvokePermission3": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "FunctionName": {
          "Ref": "UpdateCallbackStatusFunction"
        },
        "Action": "lambda:InvokeFunction",
        "Principal": "connect.amazonaws.com",
        "SourceAccount": {
          "Ref": "AWS::AccountId"
        }
      }
    }
  },
  "Outputs": {
    "DynamoDBTableName": {
      "Description": "Name of the DynamoDB table for callback requests",
      "Value": {
        "Ref": "CallbackRequestsTable"
      }
    },
    "CallbackSchedulerFunctionArn": {
      "Description": "ARN of the Callback Scheduler Lambda function",
      "Value": {
        "Fn::GetAtt": [
          "CallbackSchedulerFunction",
          "Arn"
        ]
      }
    },
    "RetrieveCallbackInfoFunctionArn": {
      "Description": "ARN of the Retrieve Callback Info Lambda function",
      "Value": {
        "Fn::GetAtt": [
          "RetrieveCallbackInfoFunction",
          "Arn"
        ]
      }
    },
    "UpdateCallbackStatusFunctionArn": {
      "Description": "ARN of the Update Callback Status Lambda function",
      "Value": {
        "Fn::GetAtt": [
          "UpdateCallbackStatusFunction",
          "Arn"
        ]
      }
    },
    "InitiateOutboundCallFunctionArn": {
      "Description": "ARN of the Initiate Outbound Call Lambda function",
      "Value": {
        "Fn::GetAtt": [
          "InitiateOutboundCallFunction",
          "Arn"
        ]
      }
    }
  }
}